# Production: copy to .env in repo root (same dir as docker-compose.prod.yml).
# Required for: docker compose -f docker-compose.prod.yml pull/up

# Image pull (GitHub username or org, lowercase for GHCR)
GITHUB_OWNER=

# Database
POSTGRES_PASSWORD=

# App (optional; DATABASE_URL is overridden by compose from POSTGRES_PASSWORD)
ADMIN_EMAIL=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=
TICKETIER_PASSWORD_SALT=
