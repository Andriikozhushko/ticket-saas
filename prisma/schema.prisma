generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  // паролей не будет, но поле можно оставить как заглушку для совместимости
  passwordHash String   @default("email_code_auth")
  role         String   @default("user") // user | org | superadmin
  createdAt    DateTime @default(now())

  organizations Organization[]
  sessions      Session[]
}

model AuthCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  events Event[]
  mono   MonoConnection?
}

model Event {
  id         String   @id @default(uuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id])

  title      String
  priceCents Int
  currency   String   @default("UAH")

  // mono
  monoAccountId String?
  monoJarId     String?

  // афиша
  startsAt   DateTime?
  venue      String?
  city       String?
  posterUrl  String?

  createdAt  DateTime @default(now())
  orders     Order[]
}

model Order {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  buyerEmail          String
  amountExpectedCents Int
  status              String // awaiting_payment | paid | expired
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  payment Payment?
  ticket  Ticket?

  @@unique([eventId, amountExpectedCents])
  @@index([eventId, status])
}

model Payment {
  id              String   @id @default(uuid())
  monoOperationId String   @unique
  amountCents     Int
  occurredAt      DateTime
  rawJson         Json

  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

model Ticket {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  qrSecretVersion Int       @default(1)
  usedAt          DateTime?
  usedBy          String?

  createdAt DateTime @default(now())
}

model MonoConnection {
  id    String       @id @default(uuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id])

  token     String
  accountId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}